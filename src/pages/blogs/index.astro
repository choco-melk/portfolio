---
import './../../global.css';
import { href } from './../../state';
import Header from './../../components/Header.astro';
import Section from './../../components/Section.astro'
import Card from './../../components/Card.astro';
import Link from './../../components/Link.astro';
import { getCollection } from 'astro:content';

href.set(`${import.meta.env.BASE_URL}/blogs`);
const blogs = (await getCollection('blogs')).reverse();
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&family=Outfit:wght@100..900&display=swap" rel="stylesheet">
		<title>Raw Blogs</title>
	</head>
	<body>
		<Header/>
		<Section>
			<div slot="heading">
				<h3 class="accentify">BLOGS</h3>
				<h1>Raw Blogs</h1>
			</div>			
			<p slot="text">
                Here are all the posts that I created for talking about my experiences and announcements. Also named the title “Raw Blogs” cause Roblox.            
            </p>		
		</Section>
		{
			blogs.map((blog) => ( 
				<Card>
					<img src={ (blog.data.image) ? `${import.meta.env.BASE_URL}/${blog.data.image}`: `${import.meta.env.BASE_URL}/assets/hyacine-2.avif`} slot="image"/>
					<div slot="heading">
						<h3 class="subheading accentify">{blog.data.date}</h3>
						<h2 class="heading">{blog.data.title}</h2>
					</div>			
					<p slot="text">
						{blog.data.preview}
					</p>
					<div slot="call-to-action" class="accentify">
						<Link href={`${import.meta.env.BASE_URL}/blogs/${blog.id}`} name="See More →"/>
					</div>
				</Card>			
			))
		}

    </body>
</html>
