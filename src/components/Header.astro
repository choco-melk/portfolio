---
import './../global.css';
import Navbar from './Navbar.astro';
---

<header>
    <Navbar/>
</header>

<style>
     @media screen and (min-width: 576px) {
        header {
            display: flex;
            justify-content: center;
            align-items: center;        
        }
    }
    
    @media screen and (min-width: 768px) {
        header {
            justify-content: flex-end;
        }
    }
</style>