---
import './../global.css';
import Navbar from './Navbar.astro';
---

<header>
    <Navbar/>
</header>

<style>
    header {
        display: flex;
        align-items: center;        
    }
    @media screen and (max-width: 576px) {
        header {
            justify-content: flex-end;
        }
    }
    @media screen and (min-width: 576px) {
        header {
            justify-content: center;
        }
    }
    
    @media screen and (min-width: 768px) {
        header {
            justify-content: flex-end;
        }
    }
</style>